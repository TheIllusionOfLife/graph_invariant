% Architecture diagram: Harmony island-model search framework
% Compile via \input{figures/architecture.tikz} inside a figure environment.
% Requires: \usepackage{tikz}
%           \usetikzlibrary{arrows.meta,positioning,fit,shapes.geometric,backgrounds}

\begin{tikzpicture}[
  island/.style={
    draw, rectangle, rounded corners=3pt,
    minimum width=3.0cm, minimum height=1.0cm,
    align=center, font=\small
  },
  component/.style={
    draw, rectangle, rounded corners=2pt,
    minimum width=2.6cm, minimum height=0.7cm,
    align=center, font=\footnotesize
  },
  main arrow/.style={-{Stealth[length=6pt]}, thick},
  dashed arrow/.style={-{Stealth[length=5pt]}, thick, dashed},
]

%% ---- Islands (surrounding the centre) ----
\node[island] (i1) at (0,  4.2) {\textbf{Island 1}\\Refine \small($T{=}0.3$)};
\node[island] (i2) at (5.5, 2.0) {\textbf{Island 2}\\Combine \small($T{=}0.3$)};
\node[island] (i3) at (0, -0.2) {\textbf{Island 3}\\Refine \small($T{=}0.8$)};
\node[island] (i4) at (-5.5, 2.0) {\textbf{Island 4}\\Novel \small($T{=}1.2$)};

%% ---- Central pipeline ----
\node[component] (llm)   at (0, 3.0) {LLM Proposer};
\node[component] (score) at (0, 2.0) {Harmony Scorer};

%% ---- MAP-Elites archive box ----
\draw[draw, thick] (-1.4, 0.4) rectangle (1.4, 1.4);
\node[font=\footnotesize\bfseries] at (0, 1.55) {MAP-Elites Archive};
\node[font=\tiny, align=center] at (0, 0.9) {$5{\times}5$ grid\\(simplicity $\times$ Harmony gain)};
% Sketch 4×4 inner grid lines to suggest cells
\foreach \x in {-0.7, 0.0, 0.7} { \draw[thin, gray] (\x, 0.4) -- (\x, 1.4); }
\foreach \y in {0.65, 0.9, 1.15} { \draw[thin, gray] (-1.4, \y) -- (1.4, \y); }

%% ---- Arrows: islands → LLM Proposer ----
\draw[main arrow] (i1.south) -- (llm.north);
\draw[main arrow] (i2.west)  -- +(-1.8,0) |- (llm.east);
\draw[main arrow] (i3.north) -- (score.south);
\draw[main arrow] (i4.east)  -- +(1.8,0)  |- (llm.west);

%% ---- Central pipeline flow ----
\draw[main arrow] (llm)   -- (score);
\draw[main arrow] (score) -- (0, 1.4);   % score → archive top

%% ---- Migration: archive → islands (dashed) ----
% Left and right via horizontal spurs
\draw[dashed arrow] (-1.4, 0.9) -- (-2.5, 0.9) |- (i4.south);
\draw[dashed arrow] ( 1.4, 0.9) -- ( 2.5, 0.9) |- (i2.south);
% Up via left-offset spur → island 1
\draw[dashed arrow] (-1.0, 1.4) -- (-1.0, 2.2) -- (-1.6, 2.2) |- (i1.west);
% Down via right-offset spur → island 3
\draw[dashed arrow] ( 1.0, 0.4) -- ( 1.0,-0.2) -- ( 1.6,-0.2) |- (i3.east);

% Migration label
\node[font=\tiny, align=center] at (-3.5, 0.0)
  {migration\\(every $M{=}10$ gen)};

\end{tikzpicture}
